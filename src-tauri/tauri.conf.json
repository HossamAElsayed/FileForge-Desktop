{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileForge",
  "version": "0.1.2",
  "identifier": "com.fileforge.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FileForge",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyMEFDN0I1MzdBREMxQUEKUldTcXdhMDN0Y2NLUWtaT0c5UHE3dDR4MnFjMnM0dkRDcUZsTDYrZ01udFhHc3BGMXYrNUNycGgK",
      "endpoints": [
        "https://github.com/HossamAElsayed/FileForge-Desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
